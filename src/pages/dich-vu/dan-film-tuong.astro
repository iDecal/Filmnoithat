---
import BaseLayout from "../../layouts/BaseLayout.astro";

const wallFeatures = [
  { 
    title: "Che khuyết điểm tuyệt đối", 
    desc: "Độ dày film cao giúp che phủ hoàn hảo các vết nứt chân chim, bề mặt tường không bằng phẳng hoặc bong tróc sơn.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`
  },
  { 
    title: "Kháng ẩm & Chống mốc", 
    desc: "Khác với giấy dán tường, film PVC không thấm nước, ngăn chặn triệt để tình trạng ẩm mốc từ bên trong tường phát ra.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0a2 2 0 01-2 2H6a2 2 0 01-2-2m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5" /></svg>`
  },
  { 
    title: "Vệ sinh cực dễ", 
    desc: "Các vết bẩn, bút mực hay dấu tay đều có thể lau sạch bằng khăn ướt mà không làm phai màu hay hỏng bề mặt.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`
  }
];

const wallTypes = [
  { name: "Vân Đá Marble", desc: "Tạo vẻ sang trọng cho vách tivi, sảnh đón khách.", img: "/images/vat-lieu/van-da.jpg" },
  { name: "Vân Gỗ Tự Nhiên", desc: "Mang lại sự ấm cúng cho phòng ngủ và phòng làm việc.", img: "/images/vat-lieu/van-go.jpg" },
  { name: "Vân Vải Sang Trọng", desc: "Thay thế giấy dán tường với độ bền gấp 5 lần.", img: "/images/vat-lieu/van-vai.jpg" },
  { name: "Màu Đơn Sắc (Matte)", desc: "Phong cách tối giản, hiện đại cho không gian căn hộ.", img: "/images/vat-lieu/mau-don-sac.jpg" }
];
---

<BaseLayout 
  title="Dán Film Nội Thất Tường - Giải Pháp Cải Tạo Vách Tường Sang Trọng"
  description="Dịch vụ dán film nội thất cho tường tại TP.HCM & Bình Dương. Thay thế giấy dán tường bằng film PVC cao cấp vân đá, vân gỗ chống ẩm mốc, bền bỉ trên 10 năm."
>

  <section class="py-24 px-6 bg-white overflow-hidden relative">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div class="relative z-10">
        <span class="text-primary-500 font-bold tracking-widest uppercase text-xs mb-4 block">Xu hướng nội thất 2026</span>
        <h1 class="text-4xl md:text-6xl font-light mb-8 italic leading-[1.1]">Biến hóa <span class="font-medium text-base-900 underline decoration-primary-500">Vách Tường</span> đơn điệu</h1>
        <p class="text-base-500 text-lg mb-10 leading-relaxed max-w-lg">
          Giải pháp dán film tường cao cấp từ Hàn Quốc giúp không gian sống trở nên đẳng cấp hơn. Chống trầy, kháng nước và bền bỉ theo thời gian.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://zalo.me/0866077040" class="bg-base-900 text-white px-10 py-4 rounded-full font-bold hover:bg-primary-500 transition-all text-center">Tư vấn chọn mẫu</a>
          <a href="/cong-trinh" class="border border-base-200 px-10 py-4 rounded-full font-bold hover:bg-base-50 transition-all text-center text-base-900">Xem công trình thật</a>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-[4/5] rounded-[4rem] overflow-hidden shadow-2xl">
          <img src="/images/services/dan-film-tuong-cover.jpg" alt="Thi công dán film tường phòng khách" class="w-full h-full object-cover" />
        </div>
        <div class="absolute top-10 -left-10 bg-white/90 backdrop-blur p-6 rounded-3xl shadow-xl border border-white/20 hidden lg:block">
          <p class="text-primary-500 font-black text-3xl">10+ Năm</p>
          <p class="text-base-900 font-medium italic">Độ bền vật liệu</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-base-50 rounded-[5rem] mx-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-3 gap-12">
        {wallFeatures.map(f => (
          <div class="group">
            <div class="bg-white p-10 rounded-[3rem] shadow-sm group-hover:shadow-2xl group-hover:-translate-y-2 transition-all duration-500 border border-base-100">
              <div class="text-primary-500 mb-6 bg-primary-50 w-16 h-16 flex items-center justify-center rounded-2xl" set:html={f.icon} />
              <h3 class="text-xl font-bold text-base-900 mb-4">{f.title}</h3>
              <p class="text-sm text-base-500 leading-relaxed">{f.detail || f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-light italic mb-4">Lựa chọn <span class="font-medium text-base-900">Bề Mặt</span></h2>
        <p class="text-base-500">Đa dạng phong cách từ cổ điển đến hiện đại</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {wallTypes.map(t => (
          <div class="group cursor-pointer">
            <div class="aspect-square rounded-3xl overflow-hidden mb-4 relative">
              <img src={t.img} alt={t.name} class="w-full h-full object-cover group-hover:scale-110 transition duration-700" />
              <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition"></div>
            </div>
            <h4 class="font-bold text-base-900 text-center group-hover:text-primary-500 transition">{t.name}</h4>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-base-900 text-white rounded-[4rem] mx-4 mb-24">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-light italic mb-8 italic">Điều kiện để dán Film tường <span class="text-primary-500">đẹp nhất?</span></h2>
      <div class="grid md:grid-cols-2 gap-8 text-left">
        <div class="bg-white/5 p-8 rounded-3xl border border-white/10">
          <h4 class="font-bold mb-3 text-primary-500">Bề mặt tường</h4>
          <p class="text-sm text-white/60 leading-relaxed">Tường cần được bả phẳng (skimming) và sơn một lớp lót để đảm bảo độ bám dính tuyệt đối của keo film. Không nên dán trực tiếp lên tường vôi cũ bong tróc.</p>
        </div>
        <div class="bg-white/5 p-8 rounded-3xl border border-white/10">
          <h4 class="font-bold mb-3 text-primary-500">Xử lý góc cạnh</h4>
          <p class="text-sm text-white/60 leading-relaxed">iDecal sử dụng kỹ thuật cắt giấu mí và khò nhiệt chuyên nghiệp, giúp các góc cột, phào chỉ trông như gỗ hoặc đá thật, không lộ vết nối.</p>
        </div>
      </div>
      
      <div class="mt-16">
        <p class="text-white/40 text-sm mb-8 italic">Bạn lo lắng về hiện trạng tường nhà mình? Hãy để chúng tôi khảo sát trực tiếp.</p>
        <a href="https://zalo.me/0866077040" class="inline-block bg-white text-base-900 px-12 py-5 rounded-full font-bold hover:bg-primary-500 hover:text-white transition-all shadow-xl">
          Đặt lịch khảo sát tại nhà (Miễn phí)
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
