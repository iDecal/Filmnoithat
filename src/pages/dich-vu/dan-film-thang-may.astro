---
import BaseLayout from "../../layouts/BaseLayout.astro";

const benefits = [
  { title: "Thi công siêu tốc", desc: "Hoàn thiện chỉ trong 4-6 tiếng, không gây gián đoạn việc di chuyển của tòa nhà." },
  { title: "Chống vân tay", desc: "Lớp phủ đặc biệt giúp bề mặt luôn sạch bóng, giảm công sức vệ sinh hàng ngày." },
  { title: "Độ bền vượt trội", desc: "Chịu được va đập từ xe đẩy, hành lý, bảo vệ lớp inox nguyên bản bên dưới." },
  { title: "Thẩm mỹ cao", desc: "Hơn 500+ mẫu vân kim loại, vân đá, vân gỗ sang trọng từ Toda, Infeel." }
];

const steps = [
  { step: "01", title: "Khảo sát & Đo đạc", detail: "Kỹ thuật viên iDecal đến tận nơi đo kích thước chi tiết các vách cabin, trần và cửa." },
  { step: "02", title: "Vệ sinh & Xử lý bề mặt", detail: "Tẩy keo cũ, xử lý các vết rỉ sét hoặc trầy xước sâu trên bề mặt inox." },
  { step: "03", title: "Thi công dán Film", detail: "Sử dụng kỹ thuật khò nhiệt và cắt giấu mí chuyên nghiệp, đảm bảo không hở viền." },
  { step: "04", title: "Nghiệm thu & Bàn giao", detail: "Kiểm tra độ bám dính và hướng dẫn khách hàng vệ sinh đúng cách." }
];
---

<BaseLayout 
  title="Dịch Vụ Dán Film Nội Thất Thang Máy - Cải Tạo Nhanh & Sang Trọng"
  description="iDecal chuyên dán film trang trí thang máy tại TP.HCM & Bình Dương. Giải pháp làm mới cabin thang máy bị trầy xước bằng film vân kim loại, vân đá cao cấp."
>

  <section class="py-24 px-6 bg-base-900 text-white overflow-hidden relative">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 items-center gap-16 relative z-10">
      <div>
        <span class="text-primary-500 font-bold tracking-[0.3em] uppercase text-xs mb-4 block">Giải pháp kiến trúc hiện đại</span>
        <h1 class="text-4xl md:text-6xl font-light mb-8 italic leading-tight">Nâng tầm <span class="font-medium">Thang Máy</span> với Film Nội Thất</h1>
        <p class="text-white/60 text-lg mb-10 leading-relaxed">
          Đừng thay mới inox đắt đỏ khi bạn có thể làm mới hoàn toàn cabin thang máy chỉ trong nửa ngày. iDecal giúp phục hồi vẻ đẹp sang trọng, đẳng cấp cho tòa nhà của bạn.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="https://zalo.me/0866077040" class="bg-primary-500 text-white px-10 py-4 rounded-full font-bold shadow-xl hover:bg-primary-600 transition-all">Liên hệ báo giá ngay</a>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-[4/5] rounded-[3rem] overflow-hidden border-8 border-white/10 shadow-2xl">
          <img src="/images/cong-trinh/dan-film-noi-that-thang-may.jpg" alt="Dán film nội thất thang máy chuyên nghiệp" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-4 gap-8">
        {benefits.map(b => (
          <div class="p-8 rounded-3xl bg-base-50 border border-base-100 hover:border-primary-500 transition-colors group">
            <h3 class="text-lg font-bold mb-4 group-hover:text-primary-500 transition">{b.title}</h3>
            <p class="text-sm text-base-500 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-base-50 rounded-[4rem] mx-4 md:mx-10 mb-24">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-light italic text-center mb-16">Quy trình thi công <span class="font-medium text-base-900">Chuẩn Kỹ Thuật</span></h2>
      <div class="grid md:grid-cols-2 gap-x-16 gap-y-12">
        {steps.map(s => (
          <div class="flex gap-6">
            <div class="text-4xl font-bold text-primary-500/20 italic">{s.step}</div>
            <div>
              <h4 class="font-bold text-base-900 mb-2">{s.title}</h4>
              <p class="text-sm text-base-500 leading-relaxed">{s.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-16">
        <h2 class="text-3xl font-light italic">Hình ảnh <span class="font-medium">Thực tế</span></h2>
        <a href="/cong-trinh" class="text-xs font-bold uppercase tracking-widest text-primary-500 border-b border-primary-500 pb-1">Xem tất cả công trình</a>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="rounded-3xl overflow-hidden aspect-square bg-base-100 shadow-lg">
          <img src="/images/projects/thang-may-1.webp" alt="Dán film inox xước thang máy" class="w-full h-full object-cover" />
        </div>
        <div class="rounded-3xl overflow-hidden aspect-square bg-base-100 shadow-lg">
          <img src="/images/projects/thang-may-2.webp" alt="Cải tạo thang máy chung cư" class="w-full h-full object-cover" />
        </div>
        <div class="rounded-3xl overflow-hidden aspect-square bg-base-100 shadow-lg">
          <img src="/images/projects/thang-may-3.webp" alt="Dán film vân gỗ thang máy" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto bg-primary-500 rounded-[3rem] p-12 text-center text-white shadow-2xl">
      <h2 class="text-3xl font-bold mb-6">Bạn đang quản lý tòa nhà hoặc cần nâng cấp thang máy?</h2>
      <p class="mb-10 text-white/80 max-w-xl mx-auto">Chúng tôi cung cấp gói giải pháp dán film trọn gói cho hệ thống thang máy văn phòng, chung cư và khách sạn với giá ưu đãi cho số lượng lớn.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://zalo.me/0866077040" class="bg-white text-primary-500 px-12 py-5 rounded-full font-bold hover:bg-base-900 hover:text-white transition-all">Gọi Zalo: 0866 077 040</a>
      </div>
    </div>
  </section>

</BaseLayout>
