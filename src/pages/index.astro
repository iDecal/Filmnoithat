---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  { title: "Thang máy vân gỗ", before: "Inox cũ", after: "Vân gỗ sang trọng" },
  { title: "Tủ bếp", before: "Xuống màu", after: "Trắng matte" },
  { title: "Văn phòng", before: "Kính trong", after: "Kính mờ riêng tư" }
];
---

<BaseLayout>

<!-- HERO -->
<section class="min-h-screen flex items-center justify-center text-center px-6">
  <div class="max-w-3xl">

    <p class="tracking-[0.3em] text-sm text-base-500 uppercase">
      Interior Film Studio
    </p>

    <h1 class="text-5xl font-light mt-6 leading-tight">
      Không gian không cần phá bỏ<br />
      <span class="font-medium">chỉ cần một lớp film mới</span>
    </h1>

    <p class="mt-6 text-base-600">
      Thang máy · Tủ bếp · Văn phòng · Showroom
    </p>

    <button class="mt-10 bg-primary-500 text-white px-6 py-3 rounded-full">
      Xem dự án
    </button>

  </div>
</section>

<!-- PROJECTS -->
<section class="py-24 px-6 bg-base-100">
  <div class="max-w-6xl mx-auto">

    <h2 class="text-2xl text-center font-light">
      Dự án thực tế
    </h2>

    <div class="grid md:grid-cols-3 gap-6 mt-12">
      {projects.map(p => (
        <div class="bg-white p-6 rounded-2xl border border-base-200">

          <h3 class="font-medium">{p.title}</h3>

          <div class="mt-4 text-sm text-base-600">
            TRƯỚC: {p.before}
          </div>

          <div class="mt-2 bg-primary-500 text-white p-2 rounded-lg text-sm">
            SAU: {p.after}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<!-- CTA -->
<section class="py-28 bg-base-900 text-white text-center">
  <h2 class="text-3xl font-light">
    Biến không gian của bạn thành phiên bản mới
  </h2>

  <button class="mt-8 bg-white text-black px-6 py-3 rounded-full">
    Liên hệ ngay
  </button>
</section>

</BaseLayout>
