---
import BaseLayout from "../layouts/BaseLayout.astro";

// Dữ liệu dịch vụ
const services = [
  { title: "Dán film thang máy", desc: "Biến kim loại lạnh thành vật liệu nội thất sang trọng, xử lý hoàn hảo mọi góc cạnh." },
  { title: "Dán film tủ bếp & tủ áo", desc: "Thay đổi màu sắc không gian bếp mà không cần thay mới, chống nước, chống dầu mỡ." },
  { title: "Dán film kính văn phòng", desc: "Tăng tính riêng tư, tạo không gian làm việc chuyên nghiệp nhưng vẫn giữ ánh sáng tự nhiên." },
  { title: "Dán nội thất Showroom", desc: "Cải tạo quầy lễ tân, kệ trưng bày cho các thương hiệu như Toyota, The Hive." }
];

// Dữ liệu dự án với ảnh thực tế
const projects = [
  { title: "Thang máy khách sạn", tag: "Premium", style: "Vân gỗ sồi sáng", img: "/images/project-thang-may.webp" },
  { title: "Văn phòng Tech", tag: "Infeel", style: "Kính mờ tối giản", img: "/images/project-van-phong.webp" },
  { title: "Nhà phố cao cấp", tag: "Toda", style: "Gỗ Walnut trầm", img: "/images/project-nha-pho.webp" }
];
---

<BaseLayout title="Film Dán Nội Thất - Vật Liệu & Thi Công Chuyên Nghiệp">

<section class="min-h-screen flex items-center justify-center px-6 relative overflow-hidden bg-base-50">
  <div class="absolute inset-0 opacity-10">
    <img src="/images/hero-pattern.webp" alt="Vân film nội thất" class="w-full h-full object-cover" />
  </div>
  <div class="relative max-w-4xl text-center">
    <p class="text-xs tracking-[0.35em] text-base-500 uppercase">Interior Film Studio</p>
    <h1 class="mt-6 text-5xl md:text-7xl font-light leading-tight text-base-900">
      Vật liệu mới cho<br />
      <span class="font-medium text-primary-500 italic text-4xl md:text-6xl text-right block md:inline">không gian cũ</span>
    </h1>
    <div class="mt-10 flex gap-4 justify-center">
      <button class="bg-primary-500 hover:bg-primary-600 text-white px-8 py-4 rounded-full transition shadow-lg">Xem dự án</button>
      <button class="border border-base-300 px-8 py-4 rounded-full hover:bg-white transition">Tư vấn vật liệu</button>
    </div>
  </div>
</section>

<section class="py-10 px-6 max-w-7xl mx-auto">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="space-y-4">
      <img src="/images/detail-1.webp" alt="Cận cảnh vân gỗ" class="rounded-2xl w-full h-64 object-cover shadow-sm hover:scale-[1.02] transition" />
      <img src="/images/detail-2.webp" alt="Thi công dán tủ" class="rounded-2xl w-full h-40 object-cover shadow-sm hover:scale-[1.02] transition" />
    </div>
    <div class="pt-8 space-y-4">
      <img src="/images/detail-3.webp" alt="Bề mặt vân đá" class="rounded-2xl w-full h-40 object-cover shadow-sm hover:scale-[1.02] transition" />
      <img src="/images/detail-4.webp" alt="Showroom Toyota" class="rounded-2xl w-full h-64 object-cover shadow-sm hover:scale-[1.02] transition" />
    </div>
    <div class="space-y-4">
      <img src="/images/detail-5.webp" alt="Cửa thang máy" class="rounded-2xl w-full h-64 object-cover shadow-sm hover:scale-[1.02] transition" />
      <img src="/images/detail-6.webp" alt="Văn phòng The Hive" class="rounded-2xl w-full h-40 object-cover shadow-sm hover:scale-[1.02] transition" />
    </div>
    <div class="pt-8 space-y-4">
      <img src="/images/detail-7.webp" alt="Mẫu film màu đơn sắc" class="rounded-2xl w-full h-40 object-cover shadow-sm hover:scale-[1.02] transition" />
      <img src="/images/detail-8.webp" alt="Kỹ thuật dán góc cạnh" class="rounded-2xl w-full h-64 object-cover shadow-sm hover:scale-[1.02] transition" />
    </div>
  </div>
</section>

<section class="py-24 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-12 items-center">
      <div>
        <h2 class="text-3xl font-light mb-8 italic text-primary-500">Giải pháp từ vật liệu bề mặt</h2>
        <div class="grid gap-6">
          {services.map(s => (
            <div class="group border-l-2 border-base-100 pl-6 hover:border-primary-500 transition">
              <h3 class="text-lg font-medium">{s.title}</h3>
              <p class="text-base-500 mt-1 text-sm">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="relative">
        <img src="/images/service-main.webp" alt="Thi công dán film chuyên nghiệp" class="rounded-3xl shadow-2xl" />
        <div class="absolute -bottom-6 -left-6 bg-primary-500 text-white p-6 rounded-2xl hidden md:block">
          <p class="text-2xl font-bold">10+</p>
          <p class="text-xs uppercase tracking-widest">Năm kinh nghiệm</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-28 px-6 bg-base-50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="text-4xl font-light">Dự án thực tế</h2>
      <p class="text-base-500 mt-4">Cảm nhận sự thay đổi từ những chi tiết nhỏ nhất</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {projects.map(p => (
        <div class="group cursor-pointer">
          <div class="overflow-hidden rounded-3xl mb-6 aspect-[4/5] relative">
            <img src={p.img} alt={p.title} class="w-full h-full object-cover group-hover:scale-110 transition duration-700" />
            <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition duration-500 flex items-center justify-center">
              <span class="bg-white text-black px-6 py-2 rounded-full text-sm font-medium">Chi tiết dự án</span>
            </div>
          </div>
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-light">{p.title}</h3>
            <span class="text-[10px] tracking-widest px-3 py-1 border border-base-300 rounded-full uppercase">{p.tag}</span>
          </div>
          <p class="text-sm text-base-400 mt-2">{p.style}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="py-24 px-6 max-w-5xl mx-auto text-center">
  <h2 class="text-3xl font-light mb-12 italic">Sự lột xác của nội thất cũ</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="relative rounded-2xl overflow-hidden">
        <img src="/images/before.webp" alt="Nội thất cũ" class="w-full h-80 object-cover" />
        <span class="absolute top-4 left-4 bg-black/50 text-white px-3 py-1 text-xs rounded">Trước</span>
    </div>
    <div class="relative rounded-2xl overflow-hidden">
        <img src="/images/after.webp" alt="Nội thất mới dán film" class="w-full h-80 object-cover" />
        <span class="absolute top-4 left-4 bg-primary-500 text-white px-3 py-1 text-xs rounded">Sau khi dán film</span>
    </div>
  </div>
</section>

<section class="py-32 bg-base-900 text-white text-center px-6 relative overflow-hidden">
  <div class="absolute inset-0 opacity-20">
    <img src="/images/cta-bg.webp" alt="Background vật liệu" class="w-full h-full object-cover" />
  </div>
  <div class="relative z-10">
    <h2 class="text-4xl font-light">Bắt đầu không gian mới ngay hôm nay</h2>
    <p class="text-white/60 mt-6 max-w-xl mx-auto text-sm leading-relaxed">
      Chúng tôi cung cấp vật liệu và giải pháp thi công dán film nội thất chuyên nghiệp cho mọi công trình tại TP.HCM & Bình Dương.
    </p>
    <button class="mt-10 bg-primary-500 text-white px-10 py-4 rounded-full hover:bg-white hover:text-black transition-all font-bold">
      Liên hệ báo giá
    </button>
  </div>
</section>

</BaseLayout>
