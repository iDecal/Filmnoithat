---
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = [
  {
    title: "Cách chọn film nội thất phù hợp cho từng không gian",
    desc: "Hướng dẫn chọn film cho bàn, tủ, tường và thang máy.",
    slug: "cach-chon-film-noi-that"
  },
  {
    title: "Báo giá dán film nội thất mới nhất",
    desc: "Cập nhật chi phí thi công film nội thất theo từng hạng mục.",
    slug: "bao-gia-dan-film"
  },
  {
    title: "Film vân gỗ là gì? Ứng dụng thực tế",
    desc: "Tìm hiểu dòng film vân gỗ trong thiết kế nội thất hiện đại.",
    slug: "film-van-go-la-gi"
  },
  {
    title: "So sánh film nội thất và sơn phủ truyền thống",
    desc: "Ưu và nhược điểm giữa film và sơn nội thất.",
    slug: "so-sanh-film-noi-that"
  }
];
---

<BaseLayout>

<!-- 🌿 HERO -->
<section class="py-24 px-6 text-center bg-gradient-to-b from-base-50 to-base-100">

  <h1 class="text-4xl font-light">
    Blog Film Nội Thất
  </h1>

  <p class="mt-4 text-base-600 max-w-2xl mx-auto">
    Kiến thức, kinh nghiệm và giải pháp thi công film nội thất thực tế.
  </p>

</section>

<!-- 🧠 BLOG GRID -->
<section class="py-24 px-6">

  <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-6">

    {posts.map(p => (
      <a href={`/blog/${p.slug}`}
        class="bg-white border border-base-200 rounded-2xl p-6 hover:shadow-lg transition">

        <h2 class="font-medium text-lg leading-snug">
          {p.title}
        </h2>

        <p class="text-sm text-base-600 mt-3">
          {p.desc}
        </p>

        <div class="mt-6 text-xs text-primary-500">
          Đọc thêm →
        </div>

      </a>
    ))}

  </div>

</section>

</BaseLayout>
