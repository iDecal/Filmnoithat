---
import BaseLayout from "../../layouts/BaseLayout.astro";

// ✅ PHẢI nằm trên cùng file
const posts = [
  {
    slug: "cach-chon-film-noi-that",
    title: "Cách chọn film nội thất phù hợp",
    content: "Nội dung bài viết về cách chọn film nội thất..."
  },
  {
    slug: "bao-gia-dan-film",
    title: "Báo giá dán film nội thất",
    content: "Chi phí thi công film nội thất..."
  },
  {
    slug: "film-van-go-la-gi",
    title: "Film vân gỗ là gì?",
    content: "Film vân gỗ là vật liệu trang trí..."
  }
];

// 🔥 BẮT BUỘC: getStaticPaths phải thấy posts
export async function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// nhận data
const { post } = Astro.props;
---

<BaseLayout>

<section class="py-24 px-6 max-w-3xl mx-auto">

  <h1 class="text-4xl font-light">
    {post.title}
  </h1>

  <article class="mt-8 text-base-700 leading-relaxed">
    {post.content}
  </article>

</section>

</BaseLayout>
