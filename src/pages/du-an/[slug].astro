---
import BaseLayout from "../../layouts/BaseLayout.astro";

// 📌 Demo data dự án (sau này thay bằng CMS)
const projects = [
  {
    slug: "van-phong-hcm",
    title: "Công trình văn phòng HCM",
    content: "Thi công film nội thất cho văn phòng hiện đại tại TP.HCM..."
  },
  {
    slug: "showroom-noi-that",
    title: "Showroom nội thất cao cấp",
    content: "Không gian showroom được nâng cấp bằng film vân gỗ & kim loại..."
  },
  {
    slug: "nha-pho-hien-dai",
    title: "Nhà phố hiện đại",
    content: "Giải pháp film nội thất giúp không gian sang trọng hơn..."
  }
];

// 🔥 BẮT BUỘC: khai báo slug cho build static
export async function getStaticPaths() {
  return projects.map((item) => ({
    params: { slug: item.slug },
    props: { project: item },
  }));
}

const { project } = Astro.props;
---

<BaseLayout>

<section class="py-24 px-6 max-w-3xl mx-auto">

  <h1 class="text-4xl font-light">
    {project.title}
  </h1>

  <article class="mt-8 text-base-700 leading-relaxed">
    {project.content}
  </article>

</section>

</BaseLayout>
