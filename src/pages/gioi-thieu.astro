---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>

<!-- 🌿 HERO -->
<section class="py-24 px-6 text-center bg-gradient-to-b from-base-50 to-base-100">

  <h1 class="text-4xl md:text-5xl font-light">
    Về chúng tôi
  </h1>

  <p class="mt-6 text-base-600 max-w-2xl mx-auto">
    Đơn vị thi công film nội thất chuyên nghiệp – mang đến giải pháp thay đổi không gian mà không cần phá bỏ cấu trúc hiện hữu.
  </p>

</section>

<!-- 🌿 STORY -->
<section class="py-24 px-6">

  <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-center">

    <!-- IMAGE -->
    <div class="h-80 bg-gradient-to-br from-base-200 to-base-300 rounded-2xl"></div>

    <!-- TEXT -->
    <div>

      <h2 class="text-3xl font-light">
        Hành trình của chúng tôi
      </h2>

      <p class="mt-4 text-base-600 leading-relaxed">
        Film nội thất không chỉ là vật liệu trang trí — đó là cách chúng tôi giúp không gian sống và làm việc
        trở nên mới mẻ, tinh tế và tiết kiệm hơn.
      </p>

      <p class="mt-4 text-base-600 leading-relaxed">
        Từ những công trình nhỏ như bàn, tủ bếp đến những dự án lớn như văn phòng và showroom,
        chúng tôi luôn chú trọng từng chi tiết thi công.
      </p>

    </div>

  </div>

</section>

<!-- 🌿 VALUES -->
<section class="py-24 px-6 bg-base-100">

  <div class="max-w-6xl mx-auto text-center">

    <h2 class="text-3xl font-light">
      Giá trị chúng tôi theo đuổi
    </h2>

    <div class="grid md:grid-cols-3 gap-6 mt-12">

      <div class="bg-white border border-base-200 rounded-2xl p-6">
        <h3 class="font-medium">Tối giản</h3>
        <p class="text-sm text-base-600 mt-2">
          Giữ nguyên cấu trúc, thay đổi bề mặt – không phá bỏ.
        </p>
      </div>

      <div class="bg-white border border-base-200 rounded-2xl p-6">
        <h3 class="font-medium">Chính xác</h3>
        <p class="text-sm text-base-600 mt-2">
          Thi công tỉ mỉ từng chi tiết, đảm bảo độ hoàn thiện cao.
        </p>
      </div>

      <div class="bg-white border border-base-200 rounded-2xl p-6">
        <h3 class="font-medium">Hiệu quả</h3>
        <p class="text-sm text-base-600 mt-2">
          Tối ưu chi phí nhưng vẫn giữ thẩm mỹ cao cấp.
        </p>
      </div>

    </div>

  </div>

</section>

<!-- 🌿 SERVICES SNAPSHOT -->
<section class="py-24 px-6">

  <div class="max-w-6xl mx-auto">

    <h2 class="text-3xl font-light text-center">
      Chúng tôi thi công
    </h2>

    <div class="grid md:grid-cols-4 gap-6 mt-12 text-center">

      <div class="p-6 bg-base-100 border border-base-200 rounded-2xl">
        <p class="font-medium">Bàn & kệ</p>
      </div>

      <div class="p-6 bg-base-100 border border-base-200 rounded-2xl">
        <p class="font-medium">Tủ bếp</p>
      </div>

      <div class="p-6 bg-base-100 border border-base-200 rounded-2xl">
        <p class="font-medium">Tường & trần</p>
      </div>

      <div class="p-6 bg-base-100 border border-base-200 rounded-2xl">
        <p class="font-medium">Thang máy</p>
      </div>

    </div>

  </div>

</section>

<!-- 🌿 CTA -->
<section class="py-28 bg-base-900 text-white text-center px-6">

  <h2 class="text-3xl font-light">
    Sẵn sàng nâng cấp không gian của bạn?
  </h2>

  <p class="text-white/60 mt-4 max-w-xl mx-auto">
    Hãy để chúng tôi giúp bạn biến không gian cũ thành một trải nghiệm mới.
  </p>

  <a href="/lien-he"
    class="inline-block mt-8 bg-white text-black px-6 py-3 rounded-full">
    Liên hệ ngay
  </a>

</section>

</BaseLayout>
