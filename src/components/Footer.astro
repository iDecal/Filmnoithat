---
// Bạn có thể đưa các thông tin này vào file cấu hình hoặc hằng số
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { title: "Dán film thang máy", href: "/dich-vu/dan-film-thang-may" },
    { title: "Dán film tủ bếp", href: "/dich-vu/dan-film-tu-bep" },
    { title: "Dán film kính văn phòng", href: "/dich-vu/dan-film-kinh-van-phong" },
    { title: "Cải tạo nội thất Showroom", href: "/dich-vu/cai-tao-showroom" },
  ],
  products: [
    { title: "Film vân gỗ cao cấp", href: "/san-pham/van-go" },
    { title: "Film vân đá Marble", href: "/san-pham/van-da" },
    { title: "Film màu đơn sắc", href: "/san-pham/mau-don-sac" },
    { title: "Vật liệu Film Infeel/Toda", href: "/san-pham/chinh-hang" },
  ],
  company: [
    { title: "Giới thiệu", href: "/gioi-thieu" },
    { title: "Dự án tiêu biểu", href: "/du-an" },
    { title: "Kiến thức nội thất", href: "/blog" },
    { title: "Chính sách bảo hành", href: "/chinh-sach-bao-hanh" },
  ]
};
---

<footer class="bg-base-900 text-white pt-20 pb-10 px-6 border-t border-white/5">
  <div class="max-w-7xl mx-auto">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div class="space-y-6">
        <div class="text-2xl font-bold tracking-tighter">
          IDEAL <span class="text-primary-500 italic">STUDIO</span>
        </div>
        <p class="text-white/50 text-sm leading-relaxed">
          Đơn vị chuyên sâu về giải pháp bề mặt nội thất. Chúng tôi giúp bạn tái tạo không gian sống bền vững, thẩm mỹ với chi phí tối ưu nhất.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary-500 transition">FB</a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary-500 transition">YT</a>
          <a href="#" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-primary-500 transition">ZL</a>
        </div>
      </div>

      <div>
        <h4 class="font-bold mb-6 uppercase text-xs tracking-widest text-primary-500">Dịch vụ thi công</h4>
        <ul class="space-y-4">
          {footerLinks.services.map(link => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-white hover:translate-x-2 transition-all inline-block text-sm">
                {link.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-bold mb-6 uppercase text-xs tracking-widest text-primary-500">Kho vật liệu</h4>
        <ul class="space-y-4">
          {footerLinks.products.map(link => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-white hover:translate-x-2 transition-all inline-block text-sm">
                {link.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-bold mb-6 uppercase text-xs tracking-widest text-primary-500">Liên hệ trực tiếp</h4>
        <ul class="space-y-4 text-sm text-white/60">
          <li class="flex items-start gap-3">
            <span>📍</span>
            <span>Trụ sở: Đường số 7, Thủ Đức, TP. Hồ Chí Minh</span>
          </li>
          <li class="flex items-start gap-3">
            <span>📍</span>
            <span>Chi nhánh: Thuận An, Bình Dương</span>
          </li>
          <li class="flex items-start gap-3">
            <span>📞</span>
            <a href="tel:0862-208-108" class="hover:text-white font-bold text-white">090x xxx xxx (Mr. Nhân)</a>
          </li>
          <li class="flex items-start gap-3">
            <span>✉️</span>
            <a href="mailto:contact@idecal.vn" class="hover:text-white">contact@idecal.vn</a>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
      
      <div class="text-white/40 text-xs">
        © {currentYear} Film Dán Nội Thất Pro. Tất cả quyền được bảo lưu. 
        <span class="block md:inline mt-2 md:mt-0">Thiết kế & SEO bởi iDecal.</span>
      </div>

      <ul class="flex gap-6 text-xs text-white/40">
        {footerLinks.company.map(link => (
          <li><a href={link.href} class="hover:text-white transition">{link.title}</a></li>
        ))}
      </ul>

    </div>

    <div class="hidden">
      <h2>Thi công dán film nội thất TP.HCM và Bình Dương chuyên nghiệp</h2>
      <p>Cung cấp film dán vân gỗ, vân đá, film kiến trúc Infeel, Toda cho tủ bếp, thang máy, văn phòng.</p>
    </div>

  </div>
</footer>

<style>
  /* Đảm bảo Footer luôn nằm dưới cùng */
  footer {
    width: 100%;
  }
</style>
