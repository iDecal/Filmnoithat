---
const nav = [
  { label: "Trang chủ", href: "/" },
  { label: "Dịch vụ", href: "/dich-vu/dan-film-noi-that" },
  { label: "Vật liệu", href: "/vat-lieu/van-go" },
  { label: "Công trình", href: "/cong-trinh/van-phong" },
  { label: "Dự án", href: "/du-an" },
  { label: "Liên hệ", href: "/lien-he" }
];
---

<header class="sticky top-0 z-50 backdrop-blur bg-white/70 border-b border-base-200">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-full bg-primary-500"></div>
      <div class="font-medium tracking-wide">
        Film Nội Thất
      </div>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-8 text-sm text-base-700">
      {nav.map(item => (
        <a href={item.href} class="hover:text-primary-500 transition">
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <a href="/lien-he"
      class="bg-primary-500 text-white text-sm px-5 py-2 rounded-full hover:opacity-90 transition">
      Tư vấn ngay
    </a>

  </div>
</header>
